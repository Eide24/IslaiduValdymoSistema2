@model IslaiduValdymoSistema.Models.Kategorija
@{
    ViewData["Title"] = " Nauja kategorija";
}
<h1>Nauja kategorija</h1>
<form asp-action="Create" method="post">
<div class="form-group">
<label asp-for="Pavadinimas" class="control-label"></label>
<input asp-for="Pavadinimas" class="form-control"/>
<span asp-validation-for="Pavadinimas" class="text-danger"></span>
</div>
<br/>
<button type="submit" class="btn btn-primary">Išsaugoti</button>
<a asp-action="Index" class="btn btn-secondary">Grįžti</a>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}