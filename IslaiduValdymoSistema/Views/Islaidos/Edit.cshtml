@model IslaiduValdymoSistema.Models.Islaida
@{
    ViewData["Title"] = "Redaguoti išlaidą";
}

<h1>Redaguoti išlaidą</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Pavadinimas" class="control-label"></label>
        <input asp-for="Pavadinimas" class="form-control" />
        <span asp-validation-for="Pavadinimas" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Suma" class="control-label"></label>
        <input asp-for="Suma" class="form-control" />
        <span asp-validation-for="Suma" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Data" class="control-label"></label>
        <input asp-for="Data" type="date" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="KategorijaId" class="control-label">Kategorija</label>
        <select asp-for="KategorijaId" class="form-control" asp-items="ViewBag.KategorijaId"></select>
        <span asp-validation-for="KategorijaId" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Išsaugoti pakeitimus</button>
        <a asp-action="Index" class="btn btn-secondary">Grįžti</a>
    </div>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}b 
