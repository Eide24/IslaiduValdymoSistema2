@model IslaiduValdymoSistema.Models.Islaida

@{
    ViewData["Title"] = "Nauja išlaida";
}

<div class="container-fluid">
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold text-primary mb-3">Nauja išlaida</h1>
            <p class="text-muted">Užpildykite žemiau esančią formą, norėdami pridėti naują išlaidą</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" novalidate>
                       
                        <div class="mb-3">
                            <label asp-for="Pavadinimas" class="form-label fw-bold">
                                <i class="bi bi-file-text"></i> Pavadinimas
                            </label>
                            <input asp-for="Pavadinimas" class="form-control form-control-lg" placeholder="Pvz. Pieno pirkinys" />
                            <span asp-validation-for="Pavadinimas" class="text-danger d-block mt-1"></span>
                        </div>

                      
                        <div class="mb-3">
                            <label asp-for="Suma" class="form-label fw-bold">
                                <i class="bi bi-currency-euro"></i> Suma (€)
                            </label>
                            <input asp-for="Suma" 
                                   type="number" 
                                   step="0.01" 
                                   min="0.01"
                                   class="form-control form-control-lg" 
                                   placeholder="pvz. 10.50" />
                            <span asp-validation-for="Suma" class="text-danger d-block mt-1"></span>
                        </div>

                      
                        <div class="mb-3">
                            <label asp-for="Data" class="form-label fw-bold">
                                <i class="bi bi-calendar-event"></i> Data
                            </label>
                            <input asp-for="Data"
                                   type="date"
                                   class="form-control form-control-lg" />
                            <span asp-validation-for="Data" class="text-danger d-block mt-1"></span>
                        </div>

                       
                        <div class="mb-4">
                            <label asp-for="KategorijaId" class="form-label fw-bold">
                                <i class="bi bi-tag"></i> Kategorija
                            </label>
                            <select asp-for="KategorijaId"
                                    class="form-select form-select-lg"
                                    asp-items="ViewBag.KategorijaId">
                                <option value="" disabled selected>-- Pasirinkite kategoriją --</option>
                            </select>
                            <span asp-validation-for="KategorijaId" class="text-danger d-block mt-1"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Grįžti
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Išsaugoti
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}