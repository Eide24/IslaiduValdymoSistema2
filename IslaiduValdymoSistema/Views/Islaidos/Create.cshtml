@model IslaiduValdymoSistema.Models.Islaida

@{
    ViewData["Title"] = "Nauja išlaida";
}

<h1>Nauja išlaida</h1>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label asp-for="Pavadinimas" class="control-label"></label>

        <input asp-for="Pavadinimas" class="form-control" />

        <span asp-validation-for="Pavadinimas"
              class="text-danger">
        </span>
    </div>

    <div class="form-group">
        <label asp-for="Suma" class="control-label"></label>

        <input asp-for="Suma" class="form-control" />

        <span asp-validation-for="Suma"
              class="text-danger">
        </span>
    </div>

    <div class="form-group">
        <label asp-for="Data" class="control-label"></label>

        <input asp-for="Data"
               type="date"
               class="form-control" />

        <span asp-validation-for="Data"
              class="text-danger">
        </span>
    </div>

    <div class="form-group">
        <label asp-for="KategorijaId"
               class="control-label">
            Kategorija
        </label>

        <select asp-for="KategorijaId"
                class="form-control"
                asp-items="ViewBag.KategorijaId">
        </select>

        <span asp-validation-for="KategorijaId"
              class="text-danger">
        </span>
    </div>

    <br />

    <button type="submit"
            class="btn btn-primary">
        Išsaugoti
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Grįžti
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}