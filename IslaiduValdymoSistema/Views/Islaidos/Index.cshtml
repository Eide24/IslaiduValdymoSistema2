@model IEnumerable<IslaiduValdymoSistema.Models.Islaida>
@{
    ViewData["Title"] = "Išlaidos";
}

<h1>Išlaidos</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">Kategorija</label>
           
            <select name="kategorijaId" class="form-control" asp-items="ViewBag.KategorijaId" value="@ViewBag.SelectedKategorijaId">
                <option value="">Visos kategorijos</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Data nuo</label>
            <input type="date" name="dataNuo" value="@ViewBag.DataNuo" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Data iki</label>
            <input type="date" name="dataIki" value="@ViewBag.DataIki" class="form-control" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Filtruoti</button>
            <a asp-action="Index" class="btn btn-secondary">Išvalyti</a>
        </div>
    </div>
</form>

<p>
    <strong>Bendra suma:</strong> @ViewBag.BendraSuma Eur
</p>

<p>
    <a asp-action="Create" class="btn btn-success">Pridėti naują išlaidą</a>
</p>


<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Pavadinimas</th>
            <th>Suma</th>
            <th>Data</th>
            <th>Kategorija</th>
            <th>Veiksmai</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var islaida in Model)
        {
            <tr>
                <td>@islaida.Pavadinimas</td>
                <td>@islaida.Suma.ToString("0.00") Eur</td> 
                <td>@islaida.Data.ToShortDateString()</td>
                <td>@islaida.Kategorija?.Pavadinimas</td>
                <td>
                    
                    <a asp-action="Edit" asp-route-id="@islaida.Id" class="btn btn-warning btn-sm">Redaguoti</a>
                    <a asp-action="Delete" asp-route-id="@islaida.Id" class="btn btn-danger btn-sm">Šalinti</a>
                </td>
            </tr>
        }
    </tbody>
</table>